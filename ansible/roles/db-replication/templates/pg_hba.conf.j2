# pg_hba.conf — Generated by Ansible (db-replication role)
# Controls who can connect to PostgreSQL and how they authenticate.

# TYPE  DATABASE        USER                    ADDRESS                 METHOD
local   all             postgres                                        peer
local   all             all                                             md5

# Allow app servers to connect to the application database
host    {{ db_name }}   {{ db_user }}           192.168.0.0/16          scram-sha-256

# Allow streaming replication from replica IPs
{% for host in groups['db_replica'] %}
host    replication     {{ postgresql_replication_user }}   {{ hostvars[host]['ansible_host'] }}/32   scram-sha-256
{% endfor %}
